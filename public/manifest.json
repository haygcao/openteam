{
  "manifest_version": 3,
  "name": "OpenTeam",
  "version": "1.0.0",
  "description": "Gemini multi-agent team discussion panel",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src *;"
  },
  "action": {
    "default_title": "OpenTeam"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*", "*://*.gemini.google.com/*", "*://chatgpt.com/*", "*://*.chatgpt.com/*", "*://chat.openai.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "gemini_iframe_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
